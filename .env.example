# Database - PostgreSQL (metadata store)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/migration_engine
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/migration_engine

# DB2 Source (mainframe)
DB2_HOST=mainframe.prudential.internal
DB2_PORT=50000
DB2_DATABASE=POLDB
DB2_USERNAME=etl_reader
DB2_PASSWORD=changeme
DB2_SCHEMA=INSURANCE

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_STAGING_BUCKET=prudential-migration-staging
S3_ARCHIVE_BUCKET=prudential-migration-archive
GLUE_DATABASE=migration_transforms
GLUE_IAM_ROLE=arn:aws:iam::123456789:role/GlueMigrationRole

# FAST Target System
FAST_API_BASE_URL=https://fast.prudential.internal/api/v2
FAST_API_KEY=changeme
FAST_BATCH_SIZE=500
FAST_MAX_RETRIES=3

# Azure OpenAI (Chatbot)
AZURE_OPENAI_ENDPOINT=https://prudential-openai.openai.azure.com
AZURE_OPENAI_API_KEY=changeme
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Migration Config
MIGRATION_BATCH_SIZE=10000
MIGRATION_PARALLEL_WORKERS=8
MIGRATION_MAX_RETRIES=3
RECONCILIATION_TOLERANCE=0.001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
